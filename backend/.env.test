# Defines test-environment defaults. Loaded automatically when APP_ENV=test.
# Real secrets MUST be placed in `.env.test.local` (git-ignored).

APP_ENV=test
APP_SECRET=test-secret-not-used-in-prod
APP_TIMEZONE=Asia/Tashkent

KERNEL_CLASS='App\Kernel'
SYMFONY_DEPRECATIONS_HELPER=999999
PANTHER_APP_ENV=panther
PANTHER_ERROR_SCREENSHOT_DIR=./var/error-screenshots

# Test DB — separate schema so functional tests can be reset on each run.
DATABASE_URL="mysql://smartpay:smartpay@127.0.0.1:3306/smartpay_crm_test?serverVersion=8.0&charset=utf8mb4"

# Test JWT passphrase. Test keys are generated into config/jwt/ on CI.
JWT_SECRET_KEY=%kernel.project_dir%/config/jwt/private-test.pem
JWT_PUBLIC_KEY=%kernel.project_dir%/config/jwt/public-test.pem
JWT_PASSPHRASE=test-passphrase-not-used-in-prod

# CORS origin used by functional auth tests.
CORS_ALLOWED_ORIGIN=http://localhost:5173

# Bootstrap admin used by AbstractApiTestCase::loginAs('admin').
INITIAL_ADMIN_PASSWORD=TestAdmin!Password2026

# In-memory messenger transport for tests.
MESSENGER_TRANSPORT_DSN=in-memory://
