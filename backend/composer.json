{
    "name": "smartpay/crm-backend",
    "description": "SmartPay CRM Backend — Symfony 7.1 REST API",
    "type": "project",
    "license": "proprietary",
    "minimum-stability": "stable",
    "prefer-stable": true,
    "require": {
        "php": ">=8.2",
        "ext-ctype": "*",
        "ext-iconv": "*",
        "ext-json": "*",
        "ext-mbstring": "*",
        "ext-openssl": "*",
        "ext-pdo": "*",
        "ext-pdo_mysql": "*",
        "symfony/flex": "^2.4",
        "symfony/framework-bundle": "^7.1",
        "symfony/runtime": "^7.1",
        "symfony/security-bundle": "^7.1",
        "symfony/serializer": "^7.1",
        "symfony/serializer-pack": "^1.3",
        "symfony/validator": "^7.1",
        "symfony/messenger": "^7.1",
        "symfony/scheduler": "^7.1",
        "symfony/rate-limiter": "^7.1",
        "symfony/http-client": "^7.1",
        "symfony/uid": "^7.1",
        "symfony/yaml": "^7.1",
        "symfony/dotenv": "^7.1",
        "symfony/console": "^7.1",
        "symfony/cache": "^7.1",
        "symfony/lock": "^7.1",
        "symfony/property-access": "^7.1",
        "symfony/property-info": "^7.1",
        "symfony/expression-language": "^7.1",
        "symfony/asset": "^7.1",
        "symfony/mime": "^7.1",
        "doctrine/orm": "^3.0",
        "doctrine/dbal": "^4.0",
        "doctrine/doctrine-bundle": "^2.12",
        "doctrine/doctrine-migrations-bundle": "^3.3",
        "lexik/jwt-authentication-bundle": "^3.0",
        "nelmio/cors-bundle": "^2.4",
        "phpoffice/phpspreadsheet": "^3.0",
        "monolog/monolog": "^3.0",
        "symfony/monolog-bundle": "^3.10"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "symfony/browser-kit": "^7.1",
        "symfony/css-selector": "^7.1",
        "symfony/maker-bundle": "^1.60",
        "symfony/phpunit-bridge": "^7.1",
        "symfony/web-profiler-bundle": "^7.1",
        "symfony/debug-bundle": "^7.1",
        "symfony/stopwatch": "^7.1",
        "doctrine/doctrine-fixtures-bundle": "^3.6",
        "phpstan/phpstan": "^1.11",
        "phpstan/phpstan-symfony": "^1.4",
        "phpstan/phpstan-doctrine": "^1.4",
        "friendsofphp/php-cs-fixer": "^3.59"
    },
    "config": {
        "allow-plugins": {
            "php-http/discovery": true,
            "symfony/flex": true,
            "symfony/runtime": true
        },
        "sort-packages": true,
        "optimize-autoloader": true,
        "preferred-install": {
            "*": "dist"
        }
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Tests\\": "tests/"
        }
    },
    "replace": {
        "symfony/polyfill-ctype": "*",
        "symfony/polyfill-iconv": "*",
        "symfony/polyfill-php72": "*",
        "symfony/polyfill-php73": "*",
        "symfony/polyfill-php74": "*",
        "symfony/polyfill-php80": "*",
        "symfony/polyfill-php81": "*",
        "symfony/polyfill-php82": "*"
    },
    "scripts": {
        "auto-scripts": {
            "cache:clear": "symfony-cmd",
            "assets:install %PUBLIC_DIR%": "symfony-cmd"
        },
        "post-install-cmd": [
            "@auto-scripts"
        ],
        "post-update-cmd": [
            "@auto-scripts"
        ],
        "test": "phpunit",
        "test:unit": "phpunit --testsuite=unit",
        "test:integration": "phpunit --testsuite=integration",
        "test:functional": "phpunit --testsuite=functional",
        "test:property": "phpunit --testsuite=property",
        "phpstan": "phpstan analyse",
        "cs-fix": "php-cs-fixer fix"
    },
    "extra": {
        "symfony": {
            "allow-contrib": false,
            "require": "7.1.*"
        }
    }
}
