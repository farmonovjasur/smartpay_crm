# Example local override file. Copy to `.env.local` and fill in real values.
# `.env.local` is git-ignored and should NEVER be committed.

APP_ENV=prod
APP_SECRET=<generate-with-openssl-rand-hex-32>

# Production MySQL connection
DATABASE_URL="mysql://smartpay:STRONG_DB_PASSWORD@127.0.0.1:3306/smartpay_crm?serverVersion=8.0&charset=utf8mb4"

# JWT signing keys (RS256). Generate with:
#   bin/console lexik:jwt:generate-keypair
JWT_PASSPHRASE=<strong-random-passphrase>

# Frontend origin (exact match, no wildcards). Required for CORS + credentials.
CORS_ALLOWED_ORIGIN=https://smartpay.netlify.app

# Initial admin bootstrap password (used once by `app:seed:initial`).
# Use a strong random value and rotate immediately after first login.
INITIAL_ADMIN_PASSWORD=<strong-random-password>

# Server timezone (must match cron and DB session timezone).
APP_TIMEZONE=Asia/Tashkent

# Messenger transport (doctrine table on prod is fine for low volume).
MESSENGER_TRANSPORT_DSN=doctrine://default
